{
  "buildCommand": "npm run build && node -e \"require('fs').copyFileSync('dist/server/server.js', 'api/server.js')\"",
  "outputDirectory": "dist/client",
  "functions": {
    "api/server.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/server.js"
    }
  ]
}
